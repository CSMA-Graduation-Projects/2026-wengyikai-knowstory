{"remainingRequest":"C:\\Users\\翁艺恺\\UserStoryLLM\\frontend\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!C:\\Users\\翁艺恺\\UserStoryLLM\\frontend\\src\\components\\TaskGraph.vue?vue&type=script&lang=js","dependencies":[{"path":"C:\\Users\\翁艺恺\\UserStoryLLM\\frontend\\src\\components\\TaskGraph.vue","mtime":1775497794852},{"path":"C:\\Users\\翁艺恺\\UserStoryLLM\\frontend\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1773340815088},{"path":"C:\\Users\\翁艺恺\\UserStoryLLM\\frontend\\node_modules\\vue-loader\\lib\\index.js","mtime":1773340815534}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["TaskGraph.vue"],"names":[],"mappings":";AAKA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"TaskGraph.vue","sourceRoot":"src/components","sourcesContent":["<template>\r\n  <div ref=\"chart\" style=\"width:100%; height:500px;\"></div>\r\n</template>\r\n\r\n<script>\r\nimport * as echarts from 'echarts';\r\n\r\nexport default {\r\n  props: ['tasks'],\r\n  watch: {\r\n    tasks: {\r\n      handler() { this.initChart(); },\r\n      deep: true\r\n    }\r\n  },\r\n  methods: {\r\n    initChart() {\r\n      if (!this.tasks || this.tasks.length === 0) return;\r\n      const myChart = echarts.init(this.$refs.chart);\r\n      \r\n      // 颜色映射：体现任务类型 \r\n      const typeColors = {\r\n        'frontend': '#409EFF',\r\n        'backend': '#67C23A',\r\n        'database': '#E6A23C',\r\n        'story': '#F56C6C'\r\n      };\r\n\r\n      // 处理节点和连线\r\n      const nodes = [];\r\n      const links = [];\r\n      const storySet = new Set();\r\n\r\n      this.tasks.forEach(task => {\r\n        // 添加任务节点\r\n        nodes.push({\r\n          name: task.name,\r\n          category: task.type,\r\n          itemStyle: { color: typeColors[task.type] }\r\n        });\r\n        // 添加依赖故事节点\r\n        if (task.dependency && !storySet.has(task.dependency)) {\r\n          nodes.push({\r\n            name: task.dependency,\r\n            category: 'story',\r\n            symbolSize: 40,\r\n            itemStyle: { color: typeColors['story'] }\r\n          });\r\n          storySet.add(task.dependency);\r\n        }\r\n        // 建立依赖关系 \r\n        links.push({ source: task.dependency, target: task.name });\r\n      });\r\n\r\n      myChart.setOption({\r\n        tooltip: {},\r\n        series: [{\r\n          type: 'graph',\r\n          layout: 'force',\r\n          data: nodes,\r\n          links: links,\r\n          roam: true,\r\n          label: { show: true, position: 'right' },\r\n          force: { repulsion: 300, edgeLength: 100 },\r\n          lineStyle: { color: '#aaa', curveness: 0.2 }\r\n        }]\r\n      });\r\n    }\r\n  }\r\n};\r\n</script>"]}]}